{
  "Logging": {
    "Console": {
      "IncludeScopes": false
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Identity": {
    "UrlServer": "https://login.microsoftonline.com/<tenant-id>",
    "TenantId": "<tenant-id>",
    "Scope": "api://<client-id>/internal-applications-jwt",
    "ClientId": "<client-id>"
  },
  "Credentials": {
    "Apis": {
      "FaceTec": {
        "Username": "user",
        "Password": "pass"
      },
      "ConsigBoilerplate": {
        "Username": "user",
        "Password": "pass"
      }
    }
  },
  "ConnectionStrings": {
    "exadataconnection": "<connection_string>",
    "redisconnection": "<connection_string>",
    "mongoconnection": "<connection_string>"
  },
  "RedisSettings": {
    "WorkerThreads": 8,
    "CompletionPortThreads": 1
  },
  "Apis": {
    "FaceTec": {
      "PathUrl": "https://facetec.com"
    },
    "ConsigBoilerplate": {
      "PathUrl": "https://wfcst.com"
    }
  },
  "ConsigBoilerplate.Api": {
    "RateLimit": {
      "MaxRequests": 1000,
      "MaxRequestsWindow": "00:00:01"
    },
    "ApiConsumptionTimeoutMs": 5000,
    "MaxPagination": 100
  },  
  "UsernameKafkaWFCST": "KafkaUserTeste",
  "PasswordKafkaWFCST": "KafkaPassTeste",
  "UsernameKafkaWFCSTCORP": "KafkaUserTeste",
  "PasswordKafkaWFCSTCORP": "KafkaPassTeste",
  "BmgKafkaSettings": {
    "Clusters": [
      {
        "Name": "MAIN-BROKER",
        "BootstrapServers": "teste",
        "Producers": [
          {
            "Name": "WEATHER-FORECAST-FINALIZED",
            "Topic": "WEATHER-FORECAST-FINALIZED",
            "IdempotenceEnabled": true
          }
        ]
      },
      {
        "Name": "CORP-BROKER",
        "BootstrapServers": "teste",
        "Producers": [
          {
            "Name": "WEATHER-FORECAST-DISTRIBUTED",
            "Topic": "WEATHER-FORECAST-DISTRIBUTED",
            "IdempotenceEnabled": true
          }
        ]
      }
    ]
  }
}
